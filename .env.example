# ─────────────────────────────────────────────────────────────
# CasGrid — Environment Variables
# ─────────────────────────────────────────────────────────────
# 1. Copy this file:   cp .env.example .env.local
# 2. Fill in the values from your Supabase project dashboard:
#    Project Settings → API
# ─────────────────────────────────────────────────────────────

# Found at: Project Settings → API → Project URL
VITE_SUPABASE_URL=https://your-project-id.supabase.co

# Found at: Project Settings → API → Project API Keys → anon / public
# This key is safe to ship in a browser bundle — it can only do what your
# Postgres grants allow. NOTE: CasGrid currently uses open shared access
# (no login, RLS disabled), so anyone with the link can view/edit the data.
# Keep the URL internal to your team.
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
